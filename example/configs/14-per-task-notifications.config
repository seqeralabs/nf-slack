/*
 * Example 14: Per-Task Notifications
 *
 * Sends Slack notifications when individual tasks complete, with
 * Nextflow-style withName/withLabel selectors. Requires enabled = true.
 */

plugins {
    id 'nf-slack@0.5.1'
}

slack {
    bot {
        token = System.getenv('SLACK_BOT_TOKEN')
        channel = System.getenv('SLACK_CHANNEL_ID')
    }
    onTaskComplete {
        enabled = true
        throttleInterval = '30s'
        onFirstFailure = true
        'withName:ALIGN.*' {
            enabled = true
            minDuration = '10m'
        }
        'withLabel:gpu' {
            enabled = true
        }
    }
}
